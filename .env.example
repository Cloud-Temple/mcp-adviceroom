# ============================================================
# AdviceRoom v0.1.1 — Configuration
# ============================================================
#
# Copier ce fichier en .env et adapter les valeurs :
#   cp .env.example .env
#
# Seules les clés API LLM sont obligatoires (au moins 2 providers).
# Les autres valeurs ont des défauts raisonnables.
#
# Documentation : README.md / DESIGN/architecture.md
# ============================================================


# ─────────────────────────────────────────────────────────────
# GENERAL
# ─────────────────────────────────────────────────────────────

# Version (informative, affichée dans /health et admin UI)
ADVICEROOM_VERSION=0.1.1

# Niveau de log : DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO


# ─────────────────────────────────────────────────────────────
# BACKEND (FastAPI + FastMCP)
# ─────────────────────────────────────────────────────────────

# Adresse et port d'écoute (interne Docker, pas exposé directement)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Token d'authentification Bootstrap (utilisé pour l'accès admin initial)
# ⚠️ CHANGER EN PRODUCTION — ce token a les permissions admin complètes
ADVICEROOM_BOOTSTRAP_KEY=adviceroom-dev-key-change-in-production-2026


# ─────────────────────────────────────────────────────────────
# LLM PROVIDERS — Au moins 2 providers requis pour un débat
# ─────────────────────────────────────────────────────────────

# --- LLMaaS (Cloud Temple SecNumCloud) ---
# 3 modèles souverains : GPT-OSS 120B, Qwen 3.5 27B, Gemma 4 31B
LLMAAS_API_URL=https://api.ai.cloud-temple.com
LLMAAS_API_KEY=your-llmaas-api-key-here
LLMAAS_DEFAULT_MODEL=qwen3.5:27b

# --- OpenAI ---
# Modèle testé : GPT-5.2 (utilise max_completion_tokens au lieu de max_tokens)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-5.2

# --- Anthropic ---
# Modèle testé : Claude Opus 4-6 (nom avec tirets, pas de points)
# ANTHROPIC_MAX_TOKENS : tokens de complétion max (défaut 64000, ne pas descendre sous 16000)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_API_URL=https://api.anthropic.com
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-6
ANTHROPIC_MAX_TOKENS=64000

# --- Google Gemini ---
# Modèle testé : Gemini 3.1 Pro
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_DEFAULT_MODEL=gemini-3.1-pro-preview


# ─────────────────────────────────────────────────────────────
# STOCKAGE S3 (persistence des débats)
# ─────────────────────────────────────────────────────────────
# Compatible Dell ECS, MinIO, AWS S3. Optionnel — sans S3, les débats
# restent uniquement en mémoire et sont perdus au redémarrage.

S3_ENDPOINT=https://your-s3-endpoint
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_BUCKET=adviceroom
S3_REGION=fr1


# ─────────────────────────────────────────────────────────────
# MCP TOOLS (outils accessibles aux LLMs pendant le débat)
# ─────────────────────────────────────────────────────────────
# Bridge vers un serveur MCP Tools externe : web_search, calculator, datetime.
# Optionnel — si non configuré, les outils sont désactivés (graceful degradation).

MCP_TOOLS_URL=https://tools.mcp.cloud-temple.app
MCP_TOOLS_TOKEN=your-mcp-tools-token-here


# ─────────────────────────────────────────────────────────────
# INFRASTRUCTURE
# ─────────────────────────────────────────────────────────────

# Redis (cache et files d'attente)
REDIS_URL=redis://redis:6379/0

# WAF Caddy + Coraza (point d'entrée HTTP, OWASP CRS v4.8.0 activé)
# En dev : accès via http://localhost:8088/admin
WAF_PORT=8088

# Auth Service (JWT RS256 — optionnel, non activé en v0.1.x)
# AUTH_SERVICE_URL=http://auth:8001
# JWT_PUBLIC_KEY_URL=http://auth:8001/.well-known/jwks.json
