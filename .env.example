# ============================================================
# AdviceRoom — Configuration
# ============================================================
# Copier ce fichier en .env et adapter les valeurs

# --- General ---
ADVICEROOM_VERSION=0.1.0
LOG_LEVEL=INFO

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- LLMaaS (Cloud Temple SecNumCloud) ---
LLMAAS_API_URL=https://api.ai.cloud-temple.com
LLMAAS_API_KEY=your-llmaas-api-key-here
LLMAAS_DEFAULT_MODEL=qwen3.5:27b

# --- Google Gemini ---
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_API_KEY=your-google-api-key-here
GOOGLE_DEFAULT_MODEL=gemini-3.1-pro-preview

# --- OpenAI ---
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-5.2

# --- Anthropic ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_API_URL=https://api.anthropic.com
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-6

# --- S3 Storage (Dell ECS) ---
S3_ENDPOINT=https://your-s3-endpoint
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_BUCKET=adviceroom
S3_REGION=fr1

# --- MCP Tools (outils pour les LLMs pendant le débat) ---
MCP_TOOLS_URL=https://tools.mcp.cloud-temple.app
MCP_TOOLS_TOKEN=your-mcp-tools-token-here

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth Service ---
AUTH_SERVICE_URL=http://auth:8001
JWT_PUBLIC_KEY_URL=http://auth:8001/.well-known/jwks.json

# --- WAF ---
WAF_PORT=443

ANTHROPIC_MAX_TOKENS=64000   # Max tokens de complétion Anthropic (défaut 64000)
