# ============================================================
# AdviceRoom — WAF Caddy Configuration
# ============================================================
# Reverse proxy + TLS + OWASP CRS via Coraza
# Ref: DESIGN/architecture.md §8

:443 {
    # TLS automatique (self-signed pour dev)
    tls internal

    # HSTS
    header Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Rate limiting
    # rate_limit {remote_host} 100r/m

    # Backend API + MCP
    handle /api/* {
        reverse_proxy backend:8000
    }
    handle /mcp* {
        reverse_proxy backend:8000
    }
    handle /health {
        reverse_proxy backend:8000
    }

    # Frontend
    handle {
        reverse_proxy frontend:3000
    }
}

# HTTP → HTTPS redirect
:80 {
    redir https://{host}{uri} permanent
}
