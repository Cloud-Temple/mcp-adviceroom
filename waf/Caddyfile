# ============================================================
# AdviceRoom — WAF Caddy + Coraza Configuration
# ============================================================
# Reverse proxy HTTP sur port 8088 (pas de TLS — géré par le reverse proxy prod)
# Sécurité: DESIGN/SECURITY_AUDIT_V1.md V1-07, V1-11, V1-16
#
# Coraza WAF activé avec OWASP CRS v4 (protection applicative).
# Rate limiting géré par le reverse proxy de production.

{
	# Charger le module Coraza en premier dans la chaîne de directives
	order coraza_waf first
}

:8088 {
	# --- WAF Coraza (OWASP CRS v4) — V1-07 ---
	coraza_waf {
		load_owasp_crs
		directives `
			Include /etc/caddy/crs/crs-setup.conf
			Include /etc/caddy/crs/rules/*.conf
			SecRuleEngine On
			SecRequestBodyAccess On
			SecResponseBodyAccess Off
			SecRequestBodyLimit 1048576
			SecRequestBodyNoFilesLimit 131072
			SecAuditEngine RelevantOnly
			SecAuditLog /dev/stderr
		`
	}

	# Pas de TLS — le reverse proxy de production (nginx/traefik) gère HTTPS
	# HSTS et TLS headers sont ajoutés par le reverse proxy prod

	# Sécurité headers (V1-16, appliqués aussi en interne par précaution)
	header X-Content-Type-Options "nosniff"
	header X-Frame-Options "DENY"
	header Referrer-Policy "strict-origin-when-cross-origin"

	# V1-11 : Admin console (proxifié par le WAF)
	handle /admin* {
		reverse_proxy backend:8000
	}

	# Backend API + MCP
	handle /api/* {
		reverse_proxy backend:8000
	}
	handle /mcp* {
		reverse_proxy backend:8000
	}
	handle /health {
		reverse_proxy backend:8000
	}

	# Frontend
	handle {
		reverse_proxy frontend:3000
	}
}
